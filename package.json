{
  "$schema": "https://json.schemastore.org/package",
  "name": "template-typescript",
  "version": "1.0.0",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.16.0",
  "type": "module",
  "scripts": {
    "lint": "eslint --fix src/**/*",
    "test": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --passWithNoTests",
    "tsconfig-generate-app": "node tsconfig-generate-app",
    "compile": "npm run lint && rimraf --glob build && node tsconfig-generate-app && tsc -project tsconfig.app.json --rootDir src --outDir build",
    "dist": "npm run compile && rimraf --glob dist && ncc build build/main.js --out dist",
    "build": "npm run dist && npm run test"
  },
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/github": "8.0.1",
    "@octokit/plugin-retry": "8.1.0",
    "@octokit/plugin-throttling": "11.0.3",
    "@octokit/rest": "22.0.1",
    "console-log-level": "1.4.1"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@eslint/js": "10.0.1",
    "@octokit/openapi-types": "27.0.0",
    "@tsconfig/node24": "24.0.4",
    "@types/console-log-level": "1.4.5",
    "@types/jest": "30.0.0",
    "@types/node": "24.12.4",
    "@types/semver": "^7",
    "@vercel/ncc": "0.38.4",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-filenames": "1.3.2",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jest": "29.15.2",
    "eslint-plugin-prettier": "5.5.6",
    "jest": "30.4.2",
    "jest-circus": "30.4.2",
    "jest-extended": "7.0.0",
    "rimraf": "6.1.3",
    "semver": "^7",
    "ts-jest": "29.4.11",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  },
  "resolutions": {
    "@octokit/openapi-types": "27.0.0",
    "@octokit/types": "16.0.0",
    "@typescript-eslint/utils": "8.61.0"
  }
}
